{
  "name": "ai-engine-execution-telemetry-preview",
  "source": "docs/design/prototypes/ai-engine-execution-telemetry-preview.html",
  "styles": {
    ":root": {
      "--bg": "#0f1115",
      "--panel": "#151821",
      "--panel-2": "#11141b",
      "--panel-3": "#191d27",
      "--text": "#e7eaf0",
      "--muted": "#9aa3b2",
      "--faint": "#6f7787",
      "--line": "#282d3a",
      "--line-soft": "#202532",
      "--good": "#61d394",
      "--warn": "#ffd166",
      "--bad": "#ff6b6b",
      "--info": "#7aa7ff",
      "--accent": "#b9c7ff",
      "--shadow": "0 20px 70px rgba(0, 0, 0, 0.34)",
      "--radius": "18px",
      "--radius-sm": "12px",
      "--mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", monospace",
      "--sans": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
    },
    "*": {
      "boxSizing": "border-box"
    },
    "html": {
      "background": "var(--bg)",
      "color": "var(--text)",
      "fontFamily": "var(--sans)",
      "lineHeight": "1.45"
    },
    "body": {
      "margin": "0",
      "minHeight": "100vh",
      "background": "radial-gradient(circle at 20% 0%, rgba(122, 167, 255, 0.10), transparent 32rem), radial-gradient(circle at 80% 20%, rgba(97, 211, 148, 0.075), transparent 28rem), var(--bg)"
    },
    "button, input, select": {
      "font": "inherit"
    },
    ".app": {
      "width": "min(1480px, calc(100vw - 40px))",
      "margin": "0 auto",
      "padding": "24px 0 48px"
    },
    ".topbar": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "18px",
      "padding": "4px 0 18px"
    },
    ".brand": {
      "display": "flex",
      "alignItems": "center",
      "gap": "12px",
      "minWidth": "0"
    },
    ".mark": {
      "display": "grid",
      "placeItems": "center",
      "width": "34px",
      "height": "34px",
      "border": "1px solid var(--line)",
      "borderRadius": "11px",
      "background": "linear-gradient(180deg, #1c2130, #121620)",
      "boxShadow": "inset 0 1px 0 rgba(255,255,255,0.05)",
      "fontWeight": "800",
      "letterSpacing": "-0.05em"
    },
    ".brand h1": {
      "margin": "0",
      "fontSize": "15px",
      "fontWeight": "680",
      "letterSpacing": "-0.01em",
      "whiteSpace": "nowrap"
    },
    ".brand p": {
      "margin": "1px 0 0",
      "color": "var(--muted)",
      "fontSize": "12px",
      "whiteSpace": "nowrap"
    },
    ".actions": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "flex-end",
      "gap": "8px",
      "flexWrap": "wrap"
    },
    ".btn": {
      "border": "1px solid var(--line)",
      "color": "var(--text)",
      "background": "rgba(21, 24, 33, 0.78)",
      "borderRadius": "999px",
      "padding": "7px 11px",
      "fontSize": "12px",
      "cursor": "pointer"
    },
    ".btn:hover": {
      "borderColor": "#3a4154",
      "background": "#1a1f2b"
    },
    ".btn.primary": {
      "borderColor": "rgba(122, 167, 255, 0.48)",
      "background": "rgba(122, 167, 255, 0.12)",
      "color": "#d8e3ff"
    },
    ".shell": {
      "display": "grid",
      "gridTemplateColumns": "270px minmax(0, 1fr) 390px",
      "gap": "16px",
      "alignItems": "start"
    },
    ".rail, .main, .detail": {
      "minWidth": "0"
    },
    ".card": {
      "background": "rgba(21, 24, 33, 0.84)",
      "border": "1px solid var(--line)",
      "borderRadius": "var(--radius)",
      "boxShadow": "var(--shadow)",
      "overflow": "hidden"
    },
    ".card.flush": {
      "boxShadow": "none"
    },
    ".section-head": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "12px",
      "padding": "14px 16px",
      "borderBottom": "1px solid var(--line-soft)"
    },
    ".section-head h2, .section-head h3": {
      "margin": "0",
      "fontSize": "12px",
      "fontWeight": "720",
      "color": "#dce3ef",
      "letterSpacing": "0.01em"
    },
    ".section-head span": {
      "fontFamily": "var(--mono)",
      "color": "var(--faint)",
      "fontSize": "11px"
    },
    ".focus": {
      "padding": "18px 18px 16px",
      "background": "linear-gradient(180deg, rgba(122,167,255,0.10), rgba(21,24,33,0))",
      "borderBottom": "1px solid var(--line-soft)"
    },
    ".eyebrow": {
      "margin": "0 0 8px",
      "color": "var(--muted)",
      "fontSize": "12px",
      "letterSpacing": "0.02em"
    },
    ".focus h2": {
      "margin": "0",
      "fontSize": "clamp(22px, 3vw, 34px)",
      "lineHeight": "1.1",
      "letterSpacing": "-0.04em"
    },
    ".focus .answer": {
      "margin": "10px 0 0",
      "maxWidth": "74ch",
      "color": "#c6cedb",
      "fontSize": "14px"
    },
    ".state-grid": {
      "display": "grid",
      "gridTemplateColumns": "repeat(4, minmax(0, 1fr))",
      "gap": "10px",
      "padding": "14px"
    },
    ".metric": {
      "border": "1px solid var(--line-soft)",
      "background": "rgba(17, 20, 27, 0.78)",
      "borderRadius": "14px",
      "padding": "12px",
      "minWidth": "0"
    },
    ".metric .label": {
      "color": "var(--muted)",
      "fontSize": "11px",
      "marginBottom": "5px"
    },
    ".metric .value": {
      "display": "flex",
      "alignItems": "baseline",
      "gap": "7px",
      "margin": "0",
      "fontSize": "20px",
      "fontWeight": "760",
      "letterSpacing": "-0.03em"
    },
    ".metric .sub": {
      "marginTop": "2px",
      "color": "var(--faint)",
      "fontFamily": "var(--mono)",
      "fontSize": "11px",
      "whiteSpace": "nowrap",
      "overflow": "hidden",
      "textOverflow": "ellipsis"
    },
    ".pill": {
      "display": "inline-flex",
      "alignItems": "center",
      "gap": "6px",
      "border": "1px solid var(--line)",
      "borderRadius": "999px",
      "padding": "4px 8px",
      "fontSize": "11px",
      "color": "var(--muted)",
      "background": "rgba(17, 20, 27, 0.72)",
      "whiteSpace": "nowrap"
    },
    ".dot": {
      "width": "7px",
      "height": "7px",
      "borderRadius": "50%",
      "background": "var(--muted)",
      "boxShadow": "0 0 0 4px rgba(154, 163, 178, 0.08)"
    },
    ".dot.good": {
      "background": "var(--good)",
      "boxShadow": "0 0 0 4px rgba(97, 211, 148, 0.10)"
    },
    ".dot.warn": {
      "background": "var(--warn)",
      "boxShadow": "0 0 0 4px rgba(255, 209, 102, 0.10)"
    },
    ".dot.bad": {
      "background": "var(--bad)",
      "boxShadow": "0 0 0 4px rgba(255, 107, 107, 0.10)"
    },
    ".dot.info": {
      "background": "var(--info)",
      "boxShadow": "0 0 0 4px rgba(122, 167, 255, 0.10)"
    },
    ".rail-block": {
      "padding": "14px",
      "borderBottom": "1px solid var(--line-soft)"
    },
    ".rail-block:last-child": {
      "borderBottom": "0"
    },
    ".nav-item": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "8px",
      "width": "100%",
      "padding": "9px 10px",
      "border": "1px solid transparent",
      "borderRadius": "12px",
      "color": "#ccd3df",
      "background": "transparent",
      "textAlign": "left",
      "cursor": "pointer",
      "fontSize": "12px"
    },
    ".nav-item:hover, .nav-item.active": {
      "background": "rgba(122, 167, 255, 0.08)",
      "borderColor": "rgba(122, 167, 255, 0.18)"
    },
    ".nav-count": {
      "color": "var(--faint)",
      "fontFamily": "var(--mono)",
      "fontSize": "11px"
    },
    ".mini-list": {
      "display": "grid",
      "gap": "9px"
    },
    ".mini-item": {
      "padding": "10px",
      "border": "1px solid var(--line-soft)",
      "borderRadius": "12px",
      "background": "rgba(17, 20, 27, 0.72)"
    },
    ".mini-item strong": {
      "display": "block",
      "fontSize": "12px",
      "fontWeight": "650",
      "color": "#dbe1ec",
      "whiteSpace": "nowrap",
      "overflow": "hidden",
      "textOverflow": "ellipsis"
    },
    ".mini-item span": {
      "display": "block",
      "marginTop": "3px",
      "color": "var(--muted)",
      "fontFamily": "var(--mono)",
      "fontSize": "11px"
    },
    ".toolbar": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "10px",
      "padding": "12px 14px",
      "borderBottom": "1px solid var(--line-soft)",
      "background": "rgba(17,20,27,0.52)"
    },
    ".filters": {
      "display": "flex",
      "alignItems": "center",
      "gap": "8px",
      "minWidth": "0",
      "overflowX": "auto",
      "paddingBottom": "1px"
    },
    ".chip": {
      "border": "1px solid var(--line)",
      "borderRadius": "999px",
      "padding": "6px 9px",
      "background": "rgba(21,24,33,0.74)",
      "color": "var(--muted)",
      "fontSize": "12px",
      "whiteSpace": "nowrap",
      "cursor": "pointer"
    },
    ".chip.active": {
      "borderColor": "rgba(122,167,255,0.48)",
      "color": "#dbe5ff",
      "background": "rgba(122,167,255,0.11)"
    },
    ".search": {
      "width": "min(260px, 32vw)",
      "border": "1px solid var(--line)",
      "borderRadius": "999px",
      "background": "rgba(11,13,18,0.42)",
      "color": "var(--text)",
      "padding": "7px 11px",
      "fontSize": "12px",
      "outline": "none"
    },
    ".search:focus": {
      "borderColor": "rgba(122,167,255,0.55)"
    },
    ".stream": {
      "display": "grid"
    },
    ".event": {
      "display": "grid",
      "gridTemplateColumns": "116px minmax(0, 1fr) auto",
      "gap": "14px",
      "padding": "13px 14px",
      "borderBottom": "1px solid var(--line-soft)",
      "cursor": "pointer"
    },
    ".event:hover, .event.selected": {
      "background": "rgba(122,167,255,0.065)"
    },
    ".event:last-child": {
      "borderBottom": "0"
    },
    ".event-time": {
      "color": "var(--muted)",
      "fontFamily": "var(--mono)",
      "fontSize": "11px",
      "whiteSpace": "nowrap"
    },
    ".event-main": {
      "minWidth": "0"
    },
    ".event-title": {
      "display": "flex",
      "alignItems": "center",
      "gap": "8px",
      "minWidth": "0",
      "margin": "0",
      "fontSize": "13px",
      "fontWeight": "680",
      "color": "#e4e9f2"
    },
    ".event-title span:last-child": {
      "whiteSpace": "nowrap",
      "overflow": "hidden",
      "textOverflow": "ellipsis"
    },
    ".event-summary": {
      "margin": "4px 0 0",
      "color": "#aeb7c7",
      "fontSize": "12px",
      "whiteSpace": "nowrap",
      "overflow": "hidden",
      "textOverflow": "ellipsis"
    },
    ".event-meta": {
      "display": "flex",
      "flexWrap": "wrap",
      "gap": "6px",
      "marginTop": "7px"
    },
    ".tag": {
      "display": "inline-flex",
      "alignItems": "center",
      "maxWidth": "230px",
      "border": "1px solid var(--line-soft)",
      "borderRadius": "999px",
      "padding": "3px 7px",
      "color": "var(--muted)",
      "fontFamily": "var(--mono)",
      "fontSize": "10px",
      "whiteSpace": "nowrap",
      "overflow": "hidden",
      "textOverflow": "ellipsis"
    },
    ".duration": {
      "alignSelf": "start",
      "color": "var(--faint)",
      "fontFamily": "var(--mono)",
      "fontSize": "11px",
      "paddingTop": "2px",
      "whiteSpace": "nowrap"
    },
    ".detail-card": {
      "position": "sticky",
      "top": "18px"
    },
    ".detail-body": {
      "padding": "14px",
      "display": "grid",
      "gap": "12px"
    },
    ".detail-title": {
      "margin": "0",
      "fontSize": "18px",
      "lineHeight": "1.18",
      "letterSpacing": "-0.03em"
    },
    ".detail-summary": {
      "margin": "0",
      "color": "#b9c2d0",
      "fontSize": "13px"
    },
    ".kv": {
      "display": "grid",
      "gridTemplateColumns": "104px minmax(0, 1fr)",
      "gap": "6px 10px",
      "padding": "12px",
      "border": "1px solid var(--line-soft)",
      "borderRadius": "14px",
      "background": "rgba(17,20,27,0.58)",
      "fontSize": "12px"
    },
    ".kv dt": {
      "color": "var(--faint)"
    },
    ".kv dd": {
      "margin": "0",
      "color": "#d6dce7",
      "minWidth": "0",
      "overflowWrap": "anywhere"
    },
    "details": {
      "border": "1px solid var(--line-soft)",
      "borderRadius": "14px",
      "background": "rgba(17,20,27,0.58)",
      "overflow": "hidden"
    },
    "summary": {
      "cursor": "pointer",
      "padding": "11px 12px",
      "color": "#dbe1eb",
      "fontSize": "12px",
      "fontWeight": "650",
      "listStyle": "none"
    },
    "summary::-webkit-details-marker": {
      "display": "none"
    },
    "summary::after": {
      "content": "\"+\"",
      "float": "right",
      "color": "var(--faint)",
      "fontFamily": "var(--mono)"
    },
    "details[open] summary::after": {
      "content": "\"â€“\""
    },
    "pre": {
      "margin": "0",
      "padding": "12px",
      "overflow": "auto",
      "borderTop": "1px solid var(--line-soft)",
      "color": "#c8d1df",
      "background": "#0b0d12",
      "fontFamily": "var(--mono)",
      "fontSize": "11px",
      "lineHeight": "1.55"
    },
    ".copy-row": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "8px",
      "padding": "10px 12px",
      "borderTop": "1px solid var(--line-soft)",
      "background": "rgba(21,24,33,0.7)"
    },
    ".copy-row span": {
      "color": "var(--faint)",
      "fontFamily": "var(--mono)",
      "fontSize": "11px"
    },
    ".plain-copy": {
      "position": "absolute",
      "left": "-9999px",
      "width": "1px",
      "height": "1px",
      "overflow": "hidden"
    },
    ".footer-note": {
      "margin": "16px 2px 0",
      "color": "var(--faint)",
      "fontSize": "12px"
    }
  },
  "media": {
    "@media (max-width: 1180px)": {
      ".shell": {
        "gridTemplateColumns": "230px minmax(0, 1fr)"
      },
      ".detail": {
        "gridColumn": "1 / -1"
      },
      ".detail-card": {
        "position": "static"
      }
    },
    "@media (max-width: 860px)": {
      ".app": {
        "width": "min(100vw - 24px, 760px)"
      },
      ".topbar": {
        "alignItems": "flex-start",
        "flexDirection": "column"
      },
      ".shell": {
        "gridTemplateColumns": "1fr"
      },
      ".state-grid": {
        "gridTemplateColumns": "repeat(2, minmax(0, 1fr))"
      },
      ".event": {
        "gridTemplateColumns": "1fr",
        "gap": "6px"
      },
      ".duration": {
        "display": "none"
      },
      ".toolbar": {
        "alignItems": "stretch",
        "flexDirection": "column"
      },
      ".search": {
        "width": "100%"
      }
    },
    "@media (max-width: 520px)": {
      ".state-grid": {
        "gridTemplateColumns": "1fr"
      }
    }
  }
}
