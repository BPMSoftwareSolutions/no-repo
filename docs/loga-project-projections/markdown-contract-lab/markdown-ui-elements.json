{
  "elements": {
    "panel": {
      "category": "content",
      "element": "section",
      "className": "loga-panel",
      "variantPrefix": "loga-panel--",
      "fields": {
        "title": {
          "element": "h3",
          "className": "loga-panel__title"
        },
        "status": {
          "element": "span",
          "className": "loga-panel__status"
        },
        "summary": {
          "element": "p",
          "className": "loga-panel__summary"
        }
      },
      "list": {
        "element": "ul",
        "itemElement": "li",
        "className": "loga-panel__content"
      },
      "children": true
    },
    "metric_row": {
      "category": "component",
      "element": "section",
      "className": "loga-metric-row",
      "itemSource": "items",
      "requiredItems": true,
      "repeatedItem": {
        "element": "article",
        "className": "loga-metric",
        "fields": {
          "label": {
            "element": "div",
            "className": "loga-metric__label",
            "required": true
          },
          "value": {
            "element": "div",
            "className": "loga-metric__value",
            "required": true
          }
        }
      }
    },
    "timeline": {
      "category": "component",
      "element": "ol",
      "className": "loga-timeline",
      "itemSource": "items",
      "requiredItems": true,
      "repeatedItem": {
        "element": "li",
        "className": "",
        "data": {
          "status": {
            "field": "status",
            "required": true
          }
        },
        "fields": {
          "step": {
            "alias": "label",
            "element": "strong",
            "required": true
          },
          "status": {
            "element": "span",
            "required": true
          }
        }
      }
    },
    "action_rail": {
      "category": "interaction",
      "element": "aside",
      "className": "loga-action-rail",
      "itemSource": "items",
      "requiredItems": true,
      "repeatedItem": {
        "element": "button",
        "className": "loga-action",
        "type": "button",
        "field": "label",
        "required": true
      }
    },
    "status_badge": {
      "category": "component",
      "element": "span",
      "className": "loga-status-badge",
      "contentField": "label",
      "required": true
    },
    "focus_strip": {
      "category": "component",
      "element": "section",
      "className": "loga-focus-strip",
      "slots": [
        {
          "element": "div",
          "fields": {
            "primaryLabel": {
              "element": "p",
              "className": "eyebrow",
              "literal": "Primary question"
            },
            "primary.question": {
              "element": "h2",
              "required": true
            },
            "primary.answer": {
              "element": "p"
            }
          }
        },
        {
          "element": "ul",
          "itemSource": "secondary",
          "repeatedItem": {
            "element": "li",
            "field": "label"
          }
        },
        {
          "element": "span",
          "className": "loga-toolbar__status",
          "field": "status"
        }
      ]
    }
  },
  "styles": {
    ":root": {
      "colorScheme": "dark",
      "--bg": "#090d14",
      "--panel": "#0f1724",
      "--ink": "#e6edf7",
      "--strong": "#f8fbff",
      "--muted": "#8b98aa",
      "--line": "#263244",
      "--accent": "#7c9cff",
      "--accent-soft": "rgba(124, 156, 255, 0.14)",
      "--green": "#3fb950",
      "--amber": "#d29922",
      "--red": "#f87171",
      "--mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", monospace",
      "--sans": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
    },
    ".projection-meta": {
      "display": "flex",
      "flexWrap": "wrap",
      "justifyContent": "space-between",
      "gap": "8px",
      "marginBottom": "24px",
      "color": "var(--muted)",
      "font": "12px/1.4 var(--mono)"
    },
    ".question-first": {
      "margin": "0 0 24px",
      "padding": "22px 0 24px",
      "borderBottom": "1px solid var(--line)"
    },
    ".question-first .label": {
      "margin": "0 0 8px",
      "color": "var(--muted)",
      "font": "12px/1.4 var(--mono)",
      "letterSpacing": "0.06em",
      "textTransform": "uppercase"
    },
    ".question-first h2": {
      "margin": "0",
      "color": "var(--strong)",
      "fontSize": "clamp(28px, 4vw, 52px)",
      "lineHeight": "1",
      "letterSpacing": "-0.06em"
    },
    ".question-first .answer": {
      "maxWidth": "78ch",
      "margin": "12px 0 0",
      "color": "var(--ink)",
      "fontSize": "17px"
    },
    ".rendered": {
      "paddingBottom": "72px"
    },
    ".rendered h1, .rendered h2, .rendered h3": {
      "color": "var(--strong)",
      "lineHeight": "1.05",
      "letterSpacing": "-0.045em"
    },
    ".rendered h1": {
      "margin": "8px 0 8px",
      "fontSize": "clamp(42px, 6vw, 76px)"
    },
    ".rendered h2": {
      "margin": "34px 0 14px",
      "fontSize": "clamp(24px, 3vw, 34px)"
    },
    ".rendered h3": {
      "margin": "0 0 6px",
      "fontSize": "20px"
    },
    ".rendered p": {
      "maxWidth": "78ch",
      "margin": "0 0 14px",
      "color": "var(--muted)"
    },
    ".rendered a": {
      "color": "var(--accent)",
      "fontWeight": "700",
      "textDecoration": "none"
    },
    ".loga-toolbar": {
      "margin": "18px 0 30px",
      "border": "1px solid var(--line)",
      "borderRadius": "18px",
      "background": "rgba(15, 23, 36, 0.72)"
    },
    ".loga-toolbar--stacked": {
      "display": "grid",
      "gridTemplateColumns": "minmax(220px, 0.8fr) minmax(280px, 1.2fr) minmax(260px, 0.9fr)",
      "gap": "14px",
      "alignItems": "start",
      "padding": "14px"
    },
    ".loga-toolbar--linear": {
      "display": "flex",
      "flexDirection": "row",
      "flexWrap": "nowrap",
      "alignItems": "flex-end",
      "gap": "10px",
      "padding": "8px 10px",
      "overflowX": "auto",
      "overflowY": "hidden",
      "whiteSpace": "nowrap"
    },
    ".loga-toolbar__group, .loga-toolbar__zone": {
      "display": "flex",
      "alignItems": "flex-end",
      "gap": "8px",
      "minWidth": "0"
    },
    ".loga-toolbar--stacked .loga-toolbar__group, .loga-toolbar--stacked .loga-toolbar__zone": {
      "flexWrap": "wrap"
    },
    ".loga-toolbar--linear .loga-toolbar__zone": {
      "flex": "0 0 auto",
      "flexWrap": "nowrap",
      "whiteSpace": "nowrap"
    },
    ".loga-toolbar--linear .loga-toolbar__zone[data-name=\"context\"], .loga-toolbar--linear .loga-toolbar__zone[data-name=\"search\"]": {
      "flexDirection": "column",
      "alignItems": "flex-start",
      "justifyContent": "flex-end"
    },
    ".loga-toolbar--linear .loga-toolbar__zone[data-name=\"navigation\"], .loga-toolbar--linear .loga-toolbar__zone[data-name=\"filters\"], .loga-toolbar--linear .loga-toolbar__zone[data-name=\"actions\"]": {
      "alignSelf": "flex-end"
    },
    ".loga-toolbar__group--left, .loga-toolbar__zone--left": {
      "justifyContent": "flex-start"
    },
    ".loga-toolbar__group--center, .loga-toolbar__zone--center": {
      "justifyContent": "center"
    },
    ".loga-toolbar__group--right, .loga-toolbar__zone--right": {
      "justifyContent": "flex-end"
    },
    ".loga-toolbar--stacked .loga-toolbar__zone--right": {
      "marginLeft": "auto"
    },
    ".loga-toolbar--linear .loga-toolbar__zone[data-name=\"context\"], .loga-toolbar--linear .loga-toolbar__zone[data-name=\"filters\"], .loga-toolbar--linear .loga-toolbar__zone[data-name=\"actions\"]": {
      "flex": "0 0 auto"
    },
    ".loga-toolbar--linear .loga-toolbar__zone[data-name=\"search\"], .loga-toolbar--linear .loga-toolbar__zone[data-align=\"center\"]": {
      "flex": "0 0 320px",
      "minWidth": "220px"
    },
    ".loga-toolbar__context": {
      "display": "grid",
      "gap": "2px",
      "minWidth": "180px"
    },
    ".loga-toolbar--linear .loga-toolbar__context": {
      "minWidth": "max-content"
    },
    ".loga-toolbar__status, .loga-status-badge, .loga-panel__status": {
      "display": "inline-flex",
      "alignItems": "center",
      "width": "max-content",
      "minHeight": "26px",
      "padding": "3px 9px",
      "border": "1px solid rgba(63, 185, 80, 0.28)",
      "borderRadius": "999px",
      "background": "rgba(63, 185, 80, 0.08)",
      "color": "var(--ink)",
      "font": "11px/1.4 var(--mono)",
      "fontWeight": "700"
    },
    ".loga-toolbar__status": {
      "minHeight": "30px",
      "padding": "4px 10px",
      "font": "12px/1.4 var(--sans)"
    },
    ".loga-control": {
      "display": "grid",
      "gap": "4px",
      "minWidth": "180px"
    },
    ".loga-toolbar--linear .loga-control": {
      "minWidth": "180px"
    },
    ".loga-control label": {
      "color": "var(--muted)",
      "font": "11px/1.3 var(--mono)",
      "letterSpacing": "0.05em",
      "textTransform": "uppercase"
    },
    ".loga-control input, .loga-control select": {
      "width": "100%",
      "minHeight": "34px",
      "padding": "0 12px",
      "border": "1px solid var(--line)",
      "borderRadius": "999px",
      "background": "rgba(3, 7, 18, 0.62)",
      "color": "var(--ink)"
    },
    ".loga-control--search": {
      "minWidth": "min(100%, 320px)",
      "flex": "1 1 320px"
    },
    ".loga-toolbar--linear .loga-control--search": {
      "width": "100%",
      "minWidth": "0",
      "flex": "0 0 auto"
    },
    ".loga-toolbar--linear .loga-control--search input": {
      "width": "100%",
      "minWidth": "0"
    },
    ".loga-chip-group, .loga-action-group, .loga-nav, .loga-actions": {
      "display": "flex",
      "flexWrap": "wrap",
      "gap": "8px"
    },
    ".loga-toolbar--linear .loga-chip-group, .loga-toolbar--linear .loga-action-group, .loga-toolbar--linear .loga-nav": {
      "flex": "0 0 auto",
      "flexWrap": "nowrap",
      "minWidth": "0"
    },
    ".loga-chip, .loga-nav a, .loga-actions button": {
      "display": "inline-flex",
      "alignItems": "center",
      "minHeight": "30px",
      "padding": "4px 10px",
      "border": "1px solid rgba(124, 156, 255, 0.42)",
      "borderRadius": "999px",
      "background": "var(--accent-soft)",
      "color": "var(--strong)",
      "fontSize": "12px",
      "fontWeight": "700",
      "flex": "0 0 auto"
    },
    ".loga-focus, .loga-surface": {
      "margin": "22px 0 30px",
      "padding": "22px 0 24px",
      "borderTop": "1px solid var(--line)",
      "borderBottom": "1px solid var(--line)"
    },
    ".loga-focus .question": {
      "margin": "0 0 10px",
      "color": "var(--strong)",
      "fontSize": "clamp(25px, 3.2vw, 42px)",
      "fontWeight": "850",
      "letterSpacing": "-0.055em",
      "lineHeight": "1"
    },
    ".loga-focus .answer, .loga-surface .answer": {
      "maxWidth": "84ch",
      "color": "var(--text)",
      "fontSize": "17px"
    },
    ".loga-breadcrumb": {
      "margin": "6px 0 18px",
      "color": "var(--muted)",
      "fontFamily": "var(--mono)",
      "fontSize": "13px"
    },
    ".loga-breadcrumb a": {
      "color": "var(--muted)",
      "fontWeight": "500"
    },
    ".loga-list": {
      "display": "grid",
      "gap": "8px",
      "margin": "18px 0 28px"
    },
    ".loga-list-item": {
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "width": "100%",
      "minHeight": "34px",
      "padding": "6px 12px",
      "border": "1px solid var(--line)",
      "borderRadius": "var(--radius-sm, 6px)",
      "color": "var(--text)",
      "fontSize": "13px",
      "fontWeight": "700"
    },
    ".loga-list-item:hover": {
      "borderColor": "var(--accent)",
      "background": "var(--accent-soft, rgba(88,166,255,0.07))",
      "color": "var(--text-strong, #fff)"
    },
    ".loga-list-item span": {
      "color": "var(--muted)",
      "fontFamily": "var(--mono)",
      "fontSize": "12px"
    },
    ".loga-primitive": {
      "marginBlock": "12px",
      "border": "1px solid var(--line)",
      "borderRadius": "var(--radius-sm, 6px)"
    },
    ".loga-kv": {
      "display": "grid",
      "gridTemplateColumns": "minmax(140px, auto) 1fr",
      "gap": "4px 20px",
      "margin": "18px 0 24px",
      "padding": "0"
    },
    ".loga-kv dt": {
      "opacity": "0.55",
      "fontWeight": "400"
    },
    ".loga-kv dd": {
      "fontWeight": "600",
      "margin": "0"
    },
    ".loga-table": {
      "width": "100%",
      "borderCollapse": "collapse",
      "margin": "18px 0 24px",
      "fontSize": "0.875em"
    },
    ".loga-table th": {
      "padding": "6px 12px",
      "textAlign": "left",
      "opacity": "0.55",
      "fontWeight": "500",
      "fontSize": "0.8em",
      "textTransform": "uppercase",
      "letterSpacing": "0.05em",
      "borderBottom": "1px solid var(--line)"
    },
    ".loga-table td": {
      "padding": "6px 12px",
      "borderBottom": "1px solid var(--line)"
    },
    ".loga-evidence-drawer": {
      "margin": "18px 0 24px",
      "borderRadius": "4px",
      "border": "1px solid var(--border)",
      "overflow": "hidden"
    },
    ".loga-evidence-drawer summary": {
      "padding": "8px 12px",
      "cursor": "pointer",
      "fontSize": "0.85em",
      "opacity": "0.7"
    },
    ".loga-evidence-drawer pre": {
      "margin": "0",
      "padding": "12px",
      "overflow": "auto",
      "fontSize": "0.8em",
      "background": "var(--panel, rgba(0,0,0,0.2))"
    },
    ".loga-panel": {
      "margin": "18px 0 24px",
      "paddingLeft": "18px",
      "borderLeft": "2px solid var(--accent)"
    },
    ".loga-panel__title": {
      "marginBottom": "8px"
    },
    ".loga-panel__summary": {
      "color": "var(--muted)"
    },
    ".loga-grid": {
      "display": "grid",
      "gap": "var(--loga-grid-gap, 16px)",
      "gridTemplateColumns": "repeat(var(--loga-grid-columns, 2), minmax(0, 1fr))",
      "margin": "18px 0 28px"
    },
    ".loga-grid .loga-panel": {
      "minWidth": "0",
      "margin": "0",
      "padding": "16px",
      "border": "1px solid var(--line)",
      "borderLeft": "2px solid var(--accent)",
      "borderRadius": "16px",
      "background": "rgba(17, 28, 43, 0.36)"
    },
    ".loga-panel ul, .loga-panel__content": {
      "margin": "10px 0 0",
      "paddingLeft": "18px",
      "color": "var(--muted)"
    },
    ".loga-panel li + li": {
      "marginTop": "6px"
    },
    ".loga-split": {
      "display": "grid",
      "gap": "16px",
      "gridTemplateColumns": "var(--loga-split-left, 2fr) var(--loga-split-right, 1fr)",
      "margin": "18px 0 28px"
    },
    ".loga-split__pane": {
      "minWidth": "0"
    },
    ".loga-stack": {
      "display": "flex",
      "flexDirection": "column",
      "gap": "var(--loga-stack-gap, 16px)",
      "margin": "18px 0 28px"
    },
    ".loga-stack > *": {
      "marginTop": "0",
      "marginBottom": "0"
    },
    ".loga-rail": {
      "position": "sticky",
      "top": "16px",
      "alignSelf": "start",
      "display": "grid",
      "gap": "8px",
      "width": "max-content",
      "maxWidth": "100%",
      "margin": "18px 0 18px auto",
      "padding": "10px",
      "border": "1px solid var(--line)",
      "borderRadius": "18px",
      "background": "rgba(15, 23, 36, 0.84)"
    },
    ".loga-rail--left": {
      "marginRight": "auto",
      "marginLeft": "0"
    },
    ".loga-focus-strip, .loga-decision-panel": {
      "display": "grid",
      "gap": "14px",
      "margin": "18px 0 28px",
      "padding": "18px",
      "border": "1px solid var(--line)",
      "borderRadius": "18px",
      "background": "linear-gradient(135deg, rgba(124, 156, 255, 0.14), rgba(17, 28, 43, 0.48))"
    },
    ".loga-focus-strip": {
      "gridTemplateColumns": "minmax(0, 1fr) minmax(220px, 0.42fr) auto",
      "alignItems": "end"
    },
    ".loga-focus-strip h2, .loga-decision-panel h3": {
      "margin": "0",
      "color": "var(--strong)",
      "letterSpacing": "-0.04em"
    },
    ".loga-focus-strip p": {
      "margin": "6px 0 0"
    },
    ".loga-focus-strip ul": {
      "margin": "0",
      "paddingLeft": "18px",
      "color": "var(--muted)"
    },
    ".loga-metric-row": {
      "display": "grid",
      "gap": "12px",
      "gridTemplateColumns": "repeat(auto-fit, minmax(150px, 1fr))",
      "margin": "18px 0 28px"
    },
    ".loga-metric": {
      "padding": "14px",
      "border": "1px solid var(--line)",
      "borderRadius": "16px",
      "background": "rgba(17, 28, 43, 0.42)"
    },
    ".loga-metric span, .loga-metric__label, .loga-timeline span, .loga-confidence": {
      "color": "var(--muted)",
      "font": "12px/1.4 var(--mono)"
    },
    ".loga-metric strong, .loga-metric__value": {
      "display": "block",
      "marginTop": "4px",
      "color": "var(--strong)",
      "fontSize": "24px",
      "letterSpacing": "-0.04em"
    },
    ".loga-timeline": {
      "display": "grid",
      "gap": "10px",
      "margin": "18px 0 28px",
      "padding": "0",
      "listStyle": "none"
    },
    ".loga-timeline li": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "12px",
      "padding": "12px 14px",
      "border": "1px solid var(--line)",
      "borderLeft": "3px solid var(--accent)",
      "borderRadius": "14px",
      "background": "rgba(17, 28, 43, 0.34)"
    },
    ".loga-timeline li[data-status=\"complete\"]": {
      "borderLeftColor": "var(--green)"
    },
    ".loga-timeline li[data-status=\"in progress\"]": {
      "borderLeftColor": "var(--amber)"
    },
    ".loga-comparison": {
      "display": "grid",
      "gap": "12px",
      "gridTemplateColumns": "repeat(2, minmax(0, 1fr))"
    },
    ".loga-comparison article": {
      "padding": "14px",
      "border": "1px solid var(--line)",
      "borderRadius": "14px",
      "background": "rgba(3, 7, 18, 0.32)"
    },
    ".loga-comparison h4": {
      "margin": "0 0 8px",
      "color": "var(--strong)"
    },
    ".loga-tree ul": {
      "margin": "0",
      "paddingLeft": "18px",
      "listStyle": "none",
      "borderLeft": "1px solid var(--line)"
    },
    ".loga-tree > ul": {
      "paddingLeft": "0",
      "borderLeft": "0"
    },
    ".loga-tree li": {
      "margin": "8px 0",
      "color": "var(--ink)"
    },
    ".loga-tree span": {
      "display": "inline-flex",
      "padding": "4px 8px",
      "borderRadius": "999px",
      "background": "rgba(124, 156, 255, 0.1)"
    },
    ".loga-action-rail": {
      "position": "sticky",
      "top": "18px",
      "float": "right",
      "display": "grid",
      "gap": "8px",
      "width": "max-content",
      "margin": "18px 0 18px 18px",
      "padding": "10px",
      "border": "1px solid var(--line)",
      "borderRadius": "999px",
      "background": "rgba(15, 23, 36, 0.84)"
    },
    ".loga-render-warning": {
      "display": "grid",
      "gap": "10px",
      "margin": "18px 0 24px",
      "padding": "16px",
      "border": "1px solid rgba(210, 153, 34, 0.34)",
      "borderLeft": "3px solid var(--amber)",
      "borderRadius": "16px",
      "background": "rgba(210, 153, 34, 0.08)"
    },
    ".loga-render-warning h3": {
      "margin": "0",
      "color": "var(--strong)"
    },
    ".loga-render-warning p": {
      "margin": "0"
    },
    "dl": {
      "display": "grid",
      "gridTemplateColumns": "minmax(130px, 0.28fr) 1fr",
      "margin": "14px 0 18px",
      "borderTop": "1px solid var(--line)"
    },
    "dt, dd": {
      "margin": "0",
      "padding": "9px 0",
      "borderBottom": "1px solid rgba(148, 163, 184, 0.16)"
    },
    "dt": {
      "color": "var(--muted)",
      "font": "11px/1.4 var(--mono)",
      "letterSpacing": "0.04em",
      "textTransform": "uppercase"
    },
    "dd": {
      "color": "var(--ink)"
    },
    "details": {
      "margin": "18px 0",
      "border": "1px solid var(--line)",
      "borderRadius": "14px",
      "background": "rgba(17, 28, 43, 0.42)",
      "overflow": "hidden"
    },
    "summary": {
      "padding": "12px 14px",
      "color": "var(--strong)",
      "font": "12px/1.4 var(--mono)",
      "letterSpacing": "0.05em",
      "textTransform": "uppercase",
      "cursor": "pointer"
    },
    "pre": {
      "margin": "0",
      "padding": "14px",
      "overflow": "auto",
      "background": "rgba(3, 7, 18, 0.8)",
      "color": "#dbeafe",
      "font": "12px/1.5 var(--mono)"
    },
    ".empty-state": {
      "display": "grid",
      "placeItems": "center",
      "minHeight": "45vh",
      "border": "1px dashed var(--line)",
      "borderRadius": "20px",
      "color": "var(--muted)",
      "textAlign": "center"
    },
    ".contract-errors": {
      "display": "grid",
      "gap": "14px",
      "margin": "18px 0 28px"
    },
    ".contract-error": {
      "padding": "18px",
      "border": "1px solid rgba(248, 113, 113, 0.36)",
      "borderLeft": "3px solid var(--red)",
      "borderRadius": "16px",
      "background": "rgba(248, 113, 113, 0.08)"
    },
    ".contract-error h3": {
      "margin": "0 0 8px",
      "color": "var(--strong)",
      "fontSize": "18px"
    },
    ".contract-error p": {
      "margin": "0 0 10px",
      "color": "var(--ink)"
    },
    ".contract-error .repair-label": {
      "marginTop": "14px",
      "color": "var(--red)",
      "font": "11px/1.4 var(--mono)",
      "letterSpacing": "0.06em",
      "textTransform": "uppercase"
    },
    ".contract-error pre": {
      "marginTop": "8px",
      "border": "1px solid rgba(248, 113, 113, 0.24)",
      "borderRadius": "12px",
      "background": "rgba(3, 7, 18, 0.72)"
    },
    ".loga-decision-panel": {
      "display": "grid",
      "gap": "14px",
      "margin": "18px 0 28px",
      "padding": "18px",
      "border": "1px solid var(--line)",
      "borderRadius": "18px",
      "background": "linear-gradient(135deg, rgba(124, 156, 255, 0.14), rgba(17, 28, 43, 0.48))"
    }
  },
  "media": {
    "@media (max-width: 980px)": {
      ".loga-toolbar--stacked": {
        "gridTemplateColumns": "1fr"
      },
      ".loga-toolbar--linear": {
        "alignItems": "flex-start"
      }
    },
    "@media (max-width: 900px)": {
      ".loga-grid, .loga-split, .loga-focus-strip, .loga-comparison": {
        "gridTemplateColumns": "1fr"
      },
      ".loga-rail": {
        "position": "static",
        "width": "auto",
        "marginRight": "0",
        "marginLeft": "0"
      }
    },
    "@media (max-width: 1100px)": {
      ".loga-toolbar--linear .loga-toolbar__zone[data-name=\"actions\"] .loga-action:not(:first-child)": {
        "display": "none"
      }
    },
    "@media (max-width: 760px)": {
      ".loga-toolbar--linear .loga-toolbar__context .eyebrow, .loga-toolbar--linear .loga-toolbar__zone[data-name=\"navigation\"] .loga-pill:nth-child(n+4)": {
        "display": "none"
      }
    }
  }
}
