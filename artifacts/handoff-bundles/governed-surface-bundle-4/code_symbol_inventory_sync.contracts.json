    "entity": "inventory.code_files",
    "operation": "read_many",
    "authorizationScope": "ai-engine.read",
    "resultCardinality": "many",
    "requiredFields": ["code_repository_id"],
    "governance": {
      "allowRuntimeFallback": false,
      "auditLevel": "high",
      "sourceOfTruth": "postgresql"
    }
  },
  "code_symbol_inventory_fetch_symbol_ids_for_file": {
    "contractKey": "code_symbol_inventory_fetch_symbol_ids_for_file",
