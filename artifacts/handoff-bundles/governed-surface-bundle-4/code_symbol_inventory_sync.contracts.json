{
  "code_symbol_inventory_fetch_repositories": {
    "contractKey": "code_symbol_inventory_fetch_repositories",
    "contractVersion": "1.0.0",
    "description": "Fetch repositories that should be scanned for symbol inventory.",
    "entity": "inventory.code_repositories",
    "operation": "read_many",
    "authorizationScope": "ai-engine.read",
    "resultCardinality": "many",
    "governance": {
      "allowRuntimeFallback": false,
      "auditLevel": "high",
      "sourceOfTruth": "postgresql"
    }
  },
  "code_symbol_inventory_fetch_files_for_repository": {
    "contractKey": "code_symbol_inventory_fetch_files_for_repository",
