    "resultCardinality": "mutation",
    "requiredFields": ["symbol_ids"],
    "governance": {
      "allowRuntimeFallback": false,
      "auditLevel": "high",
      "sourceOfTruth": "postgresql"
    }
  },
  "code_symbol_inventory_insert_symbols_batch": {
    "contractKey": "code_symbol_inventory_insert_symbols_batch",
